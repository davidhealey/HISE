    "StyleSheet": "ModalPopup",
    "Style": "\n\n#content\n{\n\tpadding: 30px 80px;\n}\n\n#total-progress\n{\n\tdisplay: none;\n}\n\n.top\n{\n\talign-items: flex-start;\n}\n\n.toggle-button\n{\n\t\n\ttext-align: left;\n}\n\n#ExportType label\n{\n\tdisplay: none;\n}\n\n#showCompiledFile label\n{\n\tdisplay: none;\n}\n\n#showPluginFolder label\n{\n\tdisplay: none;\n}\n\n.stop-button\n{\n\twidth: 0px;\n\tdisplay: none;\n}\n\n.description\n{\n\twidth: 100%;\n\ttext-align: left;\n}\n\nlabel\n{\n\tmin-width: 180px;\n}\n\n#OutputFile\n{\n\twidth: 100%;\n\ttext-align: left;\n\n\tbackground: #282828;\n\tpadding: 10px 15px;\n\tborder-radius: 2px;\n\tcolor: #888;\n}\n\n.property-button\n{\n\twidth: 600px;\n\t\n}\n\n.property-button button\n{\n\tcontent: 'Toggle All';\n\t\n}\n.property-button label\n{\n\tmax-width: 170px;\n\tfont-family: monospace;\n\tfont-size: 14px;\n}\n\n.property-column\n{\n\t\n\n\tbackground-color: red;\n}\n\n.property-tags\n{\n\tpadding-left: 190px;\n}",
    "UseViewport": true,
    "ConfirmClose": true,
    "CloseMessage": "Do you want to close this popup?",
    "DialogWidth": 800,
    "DialogHeight": 780
  },
